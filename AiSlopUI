--[[
	MinimalUI - Black Minimalistic Animated UI Library
	--------------------------------------------------
	Usage: paste into a Script (server, via command bar) or a LocalScript.
	Detects context automatically:
		- If Players.LocalPlayer exists -> parents to PlayerGui (client context)
		- If not (e.g. run from Studio command bar as "server") -> parents to StarterGui

	API:
		local UI = loadstring(...)()  -- or just run this script directly, it returns the Window

		local tab = Window:AddTab(text)           -> adds a tab to the left sidebar, returns a tab object
		tab:AddLabel(text)                        -> adds a changeable text label, returns {SetText, Get}
		tab:AddKeyLabel(caption, value)            -> split label: left = static caption (e.g.
		                                              "Enter time"), right = changeable value,
		                                              returns {SetText, Get} for the value side
		tab:AddButton(text, callback)             -> adds a clickable button
		tab:AddToggle(text, default, callback)    -> adds an animated toggle switch
		tab:AddTextbox(placeholder, callback)     -> adds a text input box
		tab:AddDivider()                          -> adds a thin horizontal separator line

		-- Window:AddLabel/AddButton/AddToggle/AddTextbox also work directly as a
		-- shortcut -- they apply to the most recently created tab (auto-creating
		-- a "General" tab if none exists yet).

	Layout: left sidebar for tab navigation, right side shows the active tab's content.
	Window is centered on screen, sized to roughly half the screen.
]]

local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

----------------------------------------------------------------
-- PARENTING LOGIC
----------------------------------------------------------------
local parent
if Players.LocalPlayer then
	parent = Players.LocalPlayer:WaitForChild("PlayerGui")
else
	parent = game:GetService("StarterGui")
end

----------------------------------------------------------------
-- THEME
----------------------------------------------------------------
local Theme = {
	Background = Color3.fromRGB(15, 15, 15),
	Panel      = Color3.fromRGB(22, 22, 22),
	Stroke     = Color3.fromRGB(40, 40, 40),
	Accent     = Color3.fromRGB(255, 255, 255),
	AccentDim  = Color3.fromRGB(90, 90, 90),
	Text       = Color3.fromRGB(235, 235, 235),
	SubText    = Color3.fromRGB(150, 150, 150),
	Font       = Enum.Font.GothamMedium,
	FontBold   = Enum.Font.GothamBold,
}

local function tween(obj, props, time, style, direction)
	local t = TweenService:Create(
		obj,
		TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out),
		props
	)
	t:Play()
	return t
end

local function corner(obj, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 8)
	c.Parent = obj
	return c
end

local function stroke(obj, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color or Theme.Stroke
	s.Thickness = thickness or 1
	s.Parent = obj
	return s
end

