local function getClosestFood(targetPart)
	local foodFolder = workspace.Interactions.Food
	local targetPos = targetPart.Position

	local closest, closestDist = nil, math.huge
	local finalCF = nil
	for _, food in foodFolder:GetChildren() do
		if food:IsA("Model") and food:GetAttribute("Value") and food:GetAttribute("Value") > 0 then
			if food.Name == "Algae" or food.Name == "Fruit" or food.Name == "Grass" or food.Name == "Berries" then
				local cf = food.PrimaryPart and food.PrimaryPart.CFrame or food:GetPivot()
				local dist = (cf.Position - targetPos).Magnitude

				if dist < closestDist then
					closest = food
					closestDist = dist
					finalCF = cf
				end
			end
		end
	end

	print(closest.Name)

	return closest, finalCF
end

local function getPingDelay()
	local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
	local ping_ms = ping / 1000

	return math.min(ping_ms, 5) or 0.5
end

local function getClosestMud(targetPart)
	local foodFolder = workspace.Interactions.Mud
	local targetPos = targetPart.Position

	local closest, closestDist = nil, math.huge
	local finalCF = nil
	for _, mood in foodFolder:GetChildren() do
		local cf = mood.CFrame
		local dist = (cf.Position - targetPos).Magnitude

		if dist < closestDist then
			closest = mood
			closestDist = dist
			finalCF = cf
		end
	end

	return closest, finalCF
end

