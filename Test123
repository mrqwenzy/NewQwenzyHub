local cache = {
	lastMission = nil,
	lastRegion = nil,
	lastHit = nil,
	DiedRecently = false,
	TailDropped = false,
	regionChildren = {},
	shoomChildren = {},
	lastCacheUpdate = 0,
	cacheInterval = 0.5,
}

local function findMission(currentTime)
	if currentTime - cache.lastCacheUpdate > cache.cacheInterval then
		cache.regionChildren = RegionMissions:GetChildren()
		cache.shoomChildren = ShoomPiles:GetChildren()
		cache.lastCacheUpdate = currentTime
	end

	if canSniff then
		for i = 1, #cache.regionChildren do
			local _region = cache.regionChildren[i]
			if regions[_region.Name] and _region.Sniff.Amount.Value < _region.Sniff.TargetAmount.Value then
				return "Sniff", _region.Name
			end
		end
	end

	-- Priority 2: ShoomPile
	for i = 1, #cache.shoomChildren do
		local v = cache.shoomChildren[i]
		if v:IsA("Model") and v.Name ~= "Nodes" then
			local shoomPart = v:FindFirstChild("Shoom")
			if shoomPart and shoomPart.Transparency == 0 then
				return "ShoomPile", "Whatever", v
			end
		end
	end

	-- Priority 3: EatFoodDrinkWater
	local slot = getSlot()
	if getHungerInfo() and getThirstInfo() then
		if slot then
			local food, maxfood = getHungerInfo()
			local water, maxwater = getThirstInfo()
			if maxwater - water > 5 or maxfood - food > 5 then
				for i = 1, #cache.regionChildren do
					local _region = cache.regionChildren[i]
					if regions[_region.Name] then
						local eatFood = _region:FindFirstChild("EatFoodDrinkWater")
						if eatFood and eatFood.Amount.Value < eatFood.TargetAmount.Value then
							return "EatFoodDrinkWater", _region.Name
						end
					end
				end
			else
				if not cache.TailDropped and not busy then
					cache.TailDropped = true
					task.delay(10, function()
						cache.TailDropped = false
					end)

					local Event = ReplicatedStorage.Remotes.ActivateAbility
					Event:FireServer("TailDrop")
				end
			end
		end
	end
	-- Priority 4: ConcealScent
	for i = 1, #cache.regionChildren do
		local _region = cache.regionChildren[i]
		if regions[_region.Name] then
			local concealScent = _region:FindFirstChild("ConcealScent")
			if concealScent and concealScent.Amount.Value < concealScent.TargetAmount.Value then
				return "ConcealScent", _region.Name
			end
		end
	end

	-- Priority 5: DistanceTravelled
	for i = 1, #cache.regionChildren do
		local _region = cache.regionChildren[i]
		if
			regions[_region.Name]
			and _region.DistanceTravelled.Amount.Value < _region.DistanceTravelled.TargetAmount.Value
		then
			return "DistanceTravelled", _region.Name
		end
	end

	-- Priority 6: AttackOrHealCreatureOrNPC
	for i = 1, #cache.regionChildren do
		local _region = cache.regionChildren[i]
		if regions[_region.Name] then
			local attackHeal = _region:FindFirstChild("AttackOrHealCreatureOrNPC")
			if attackHeal and attackHeal.Amount.Value < attackHeal.TargetAmount.Value then
				return "AttackOrHealCreatureOrNPC", _region.Name
			end
		end
	end

	-- Priority 7: TimePlayed
	for i = 1, #cache.regionChildren do
		local _region = cache.regionChildren[i]
		if regions[_region.Name] and _region.TimePlayed.Amount.Value < _region.TimePlayed.TargetAmount.Value then
			return "TimePlayed", _region.Name
		end
	end

	return nil, nil
end

local function executeMission(mission, region, shoom, humr)
	if mission == "DistanceTravelled" then
		CONFIG.State = "Traveling distance"
		busy = true
		task.delay(4, function()
			busy = false
		end)

		local randomOffset = CFrame.new(-300, 0, -300)
		TweenService:Create(humr, TweenInfo.new(0.5), {
			CFrame = positionStringToCFrame(regions[region].Position) * randomOffset,
		}):Play()
		task.wait(2.5)
		changeRegionRemote(region)

		TweenService:Create(humr, TweenInfo.new(0.5), {
			CFrame = positionStringToCFrame(regions[region].Position) * CFrame.new(300, 0, 300),
		}):Play()
	elseif mission == "Sniff" then
		if currRegion ~= region then
			CONFIG.State = "Sniff"
			busy = true
			task.delay(0.6, function()
				busy = false
				changeRegionRemote(region)
			end)
			TweenService:Create(humr, TweenInfo.new(0.6), {
				CFrame = positionStringToCFrame(regions[region].Position),
			}):Play()
			currRegion = region
		else
			local food, cf = getClosestFood(humr)
			if food then
				CONFIG.State = "Sniff"
				busy = true
				task.delay(1.5, function()
					busy = false
				end)
				TweenService:Create(humr, TweenInfo.new(0.5), { CFrame = cf }):Play()
				task.wait(1)
				print("eat")
				clickButton(Enum.KeyCode.H)
				canSniff = false
				task.delay(15, function()
					canSniff = true
				end)

				if food.Name == "Algae" or food.Name == "Grass" then
					eatFood(food)
				end
				currRegion = nil
			else
				clickButton(Enum.KeyCode.Three)
			end
		end
	elseif mission == "EatFoodDrinkWater" then
		CONFIG.State = "EatFoodDrinkWater"
		if currRegion ~= region then
			CONFIG.State = "EatFoodDrinkWater 1/2"
			busy = true
			task.delay(0.6, function()
				busy = false
				changeRegionRemote(region)
			end)
			TweenService:Create(humr, TweenInfo.new(0.6), {
				CFrame = positionStringToCFrame(regions[region].Position),
			}):Play()
			currRegion = region
		else
			local food, cf = getClosestFood(humr)
			if food then
				CONFIG.State = "EatFoodDrinkWater 2/2"
				busy = true
				task.delay(1, function()
					busy = false
				end)
				TweenService:Create(humr, TweenInfo.new(0.5), { CFrame = cf }):Play()
				drinkWater()
				eatFood(food)

				task.wait(0.5)

				humr.Velocity = Vector3.zero
			end
		end
	elseif mission == "ShoomPile" then
		busy = true
		task.delay(0.5, function()
			busy = false
		end)
		CONFIG.State = "Traveling to Shoom"
		if shoom then
			CONFIG.State = "Picking up Shoom"
			TweenService:Create(humr, TweenInfo.new(0.5), {
				CFrame = shoom.WorldPivot,
			}):Play()
			clickButton(Enum.KeyCode.E)
		end
	elseif mission == "ConcealScent" then
		CONFIG.State = "ConcealScent"
		if currRegion ~= region then
			CONFIG.State = "ConcealScent: 1/2"
			busy = true
			task.delay(0.5, function()
				busy = false
				changeRegionRemote(region)
			end)
			TweenService:Create(humr, TweenInfo.new(0.5), {
				CFrame = positionStringToCFrame(regions[region].Position),
			}):Play()
			currRegion = region
		else
			local mud, cf = getClosestMud(humr)
			if mud then
				CONFIG.State = "ConcealScent 2/2"
				busy = true
				task.delay(1.5, function()
					busy = false
				end)
