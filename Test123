local function positionStringToCFrame(s)
	local x, y, z = string.match(s, "(-?%d+%.?%d*),%s*(-?%d+%.?%d*),%s*(-?%d+%.?%d*)")
	return CFrame.new(tonumber(x), tonumber(y), tonumber(z))
end

