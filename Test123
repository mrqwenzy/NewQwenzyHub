			if #aliveBums > 0 then
				busy = true
				task.delay(0.5, function()
					busy = false
				end)
				for _, bum in ipairs(aliveBums) do
					CONFIG.State = "Killing " .. bum.Name
					for _ = 1, 5 do
						attackTarget(bum)
					end
				end
			else
				local health, maxhealth = getHealth(getSlot())

				if health > maxhealth / 2 then
					busy = true
					task.delay(0.5, function()
						busy = false
					end)

					local Event = game:GetService("ReplicatedStorage").Remotes.CharactersDamageRemote
					Event:FireServer({
						Players.LocalPlayer.Character,
					}, nil)
					cache.lastHit = tick()
				end
			end

			currRegion = region
		end
	end
end

cns.Render = RunService.RenderStepped:Connect(function()
	if getgenv().Ver ~= currver then
		for _, cn in cns do
			cn:Disconnect()
			active = false
		end
		return
	end

	if busy or not CONFIG.Autofarm then
		return
	end

	CONFIG.State = "Autofarm"
	local char = localPlayer.Character
	local humr = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not humr then
		return
	end

	if DPointsText and not cache.DiedRecently then
		if tonumber(DPointsText.Text) == nil then
			buttonClickSignal(
				game:GetService("Players").LocalPlayer.PlayerGui.CreatureInfoGui.ContainerFrame.TabButtons.TopFrame.SurvivalStats.UpperLabel
			)
		end
		busy = true

		if tonumber(DPointsText.Text) >= 750 then
			buttonClickSignal(
				game:GetService("Players").LocalPlayer.PlayerGui.CreatureInfoGui.ContainerFrame.TabButtons.TopFrame.SurvivalStats.UpperLabel
			)
			task.wait(3)
			if tonumber(DPointsText.Text) < 750 then
				busy = false

				return
			end
			if cache.lastHit then
				if tick() - cache.lastHit < 20 then
					busy = false
					return
				end
			end
			while task.wait() do
				TweenService:Create(humr, TweenInfo.new(8), {
					CFrame = CFrame.new(0, 5000, 0),
				}):Play()
				task.wait(4)
				if char and char.Parent and humr and humr.Parent then
					TweenService:Create(humr, TweenInfo.new(0.5), {
						CFrame = CFrame.new(0, 5000, 0),
					}):Play()
					humr.Velocity = Vector3.new(0, 1, 0)
				else
					break
				end
			end
			cache.DiedRecently = true

			task.delay(20, function()
				cache.DiedRecently = false
			end)

			busy = false
		else
			warn(DPointsText.Text)
		end
	end

	local mission, region, shoom = findMission(tick())

	if mission and region then
		print(mission .. " " .. region)
		executeMission(mission, region, shoom, humr)
	else
		CONFIG.State = "Waiting for available mission"
		warn("Mission not found")
	end
end)
