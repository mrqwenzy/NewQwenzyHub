		ballESP.tracer:Remove()
		ballESP.tracer = nil
	end
	if ballESP.distLabel then
		ballESP.distLabel:Remove()
		ballESP.distLabel = nil
	end
end

local function updateBallESP(ball, myChar)
	if not Config.BallESP or not ball then
		if ballESP.tracer then
			ballESP.tracer.Visible = false
			ballESP.distLabel.Visible = false
		end
		return
	end

	-- Hide when ball is inside our character
	if not getBall() then
		ballESP.tracer.Visible = false
		ballESP.distLabel.Visible = false
		return
	end

	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myRoot then
		ballESP.tracer.Visible = false
		ballESP.distLabel.Visible = false
		return
	end

	local ballPos, ballOnScreen = workspace.CurrentCamera:WorldToViewportPoint(getBall().Position)
	local rootPos, rootOnScreen = workspace.CurrentCamera:WorldToViewportPoint(myRoot.Position)

	if not ballOnScreen or not rootOnScreen then
		ballESP.tracer.Visible = false
		ballESP.distLabel.Visible = false
		return
	end

	-- Tracer: from rootpart screen pos → ball screen pos
	ballESP.tracer.From = Vector2.new(rootPos.X, rootPos.Y)
	ballESP.tracer.To = Vector2.new(ballPos.X, ballPos.Y)
	ballESP.tracer.Visible = true

	-- Distance label above ball
	local dist = math.floor((ball.Position - myRoot.Position).Magnitude)
	ballESP.distLabel.Text = dist .. " studs"
	ballESP.distLabel.Position = Vector2.new(ballPos.X, ballPos.Y - 18)
	ballESP.distLabel.Visible = true
end

