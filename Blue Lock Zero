local function playAnimation(char: Model, anim: Animation | string)
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		return
	end

	-- Handle string ID or Animation instance
	local animation
	if typeof(anim) == "string" or typeof(anim) == "number" then
		animation = Instance.new("Animation")
		animation.AnimationId = "rbxassetid://" .. tostring(anim):match("%d+")
	elseif typeof(anim) == "Instance" and anim:IsA("Animation") then
		animation = anim
	else
		warn("Invalid animation argument")
		return
	end

	local track = animator:LoadAnimation(animation)
	track:Play()
	return track -- return track so you can stop/manipulate it later
end
local function getClosestCharacter(folder, distance)
	local target = nil
	local closestDistance = distance

	for _, currChar in ipairs(folder:GetChildren()) do
		local rootPart = currChar:FindFirstChild("HumanoidRootPart")
		if rootPart and currChar ~= character() then
			local dist = (rootPart.Position - getcharacter().HumanoidRootPart.Position).Magnitude
			if dist < closestDistance then
				closestDistance = dist
				target = currChar
			end
		end
	end

	return target, closestDistance
end
