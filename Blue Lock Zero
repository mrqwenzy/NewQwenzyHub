local Config = {}

local function cloneDefault()
	local t = {}

	for key, value in pairs(DEFAULT_CONFIG) do
		t[key] = value
	end

	return t
end

local function saveCFG()
	writefile(file, HttpService:JSONEncode(Config))
end

local function loadCFG()
	if not isfile(file) then
		Config = cloneDefault()
		saveCFG()
		return Config
	end

	local success, data = pcall(function()
		return HttpService:JSONDecode(readfile(file))
	end)

	if not success or type(data) ~= "table" then
		Config = cloneDefault()
		saveCFG()
		return Config
	end

	for key, value in pairs(DEFAULT_CONFIG) do
		if data[key] == nil then
			data[key] = value
		end
	end

	Config = data
	saveCFG()

	return Config
end

local function setCFG(key, value)
	Config[key] = value
	saveCFG()
end

local function getCFG(key)
	return Config[key]
end

local function resetCFG()
	Config = cloneDefault()
	saveCFG()
	return Config
end

