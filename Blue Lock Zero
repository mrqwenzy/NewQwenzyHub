cns.Cycle = RunService.Stepped:Connect(function()
	if Ver.Value ~= currVer then
		for _, v in pairs(cns) do
			v:Disconnect()
		end
		for _, v in pairs(dribbleConns) do
			v:Disconnect()
		end
		if dribbleDescConn then
			dribbleDescConn:Disconnect()
		end
		removeBallDrawings()
		saveCFG()

		return
	end

	if Config.InfStamina then
		Players.LocalPlayer:SetAttribute("STAMINA", 99)
	end

	if getBall() then
		updateBallESP(getBall(), character())
	end

	if getCFG("Speed") and getCFG("Speed") ~= 0 then
		local humr = character().HumanoidRootPart
		local vel = humr.AssemblyLinearVelocity

		local flat = Vector3.new(vel.X, 0, vel.Z)
		local speed = flat.Magnitude

		if speed > 2 and not humr.Anchored then
			local dir = flat.Unit
			humr.CFrame += dir * (getCFG("Speed") / 100)
		end
	end
end)

