local dribbleConns = {}
local dribbleDescConn = nil
local isDribbling = false

local function skey(kc, down)
	setthreadidentity(8)
	VirtualInputManager:SendKeyEvent(down, kc, false, game)
end

local function dribble()
	if isDribbling then
		return
	end
	isDribbling = true

	local ok, kc = pcall(function()
		return Enum.KeyCode[getCFG("DribbleKey")]
	end)
	if not ok or not kc then
		isDribbling = false
		return
	end

	if not pcall(skey, kc, true) then
		keypress(kc.Value)
	end
	task.delay(getCFG("DribbleWait"), function()
		if not pcall(skey, kc, false) then
			keyrelease(kc.Value)
		end
		isDribbling = false
	end)
end

local function hookDribble(hum)
	local char = hum.Parent
	if not char or dribbleConns[char] or char == Players.LocalPlayer.Character then
		return
	end

	local anim = hum:FindFirstChildOfClass("Animator")
	if not anim then
		local c
		c = hum.ChildAdded:Connect(function(ch)
			if ch:IsA("Animator") then
				c:Disconnect()
				hookDribble(hum)
			end
		end)
		return
	end

	dribbleConns[char] = anim.AnimationPlayed:Connect(function(trk)
		if not Config.AutoDribble then
			return
		end

		-- Distance check
		local lhrp = character():FindFirstChild("HumanoidRootPart")
		if not lhrp then
			return
		end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then
			return
		end
		if (hrp.Position - lhrp.Position).Magnitude > getCFG("ad_dist") then
			return
		end

		local animId = trk.Animation.AnimationId:match("%d+$")
		if not animId then
			return
		end

		-- Check if this animation ID is in our dribble list
		local shouldDribble = false
		for _, id in ipairs(getCFG("DribbleAnimIds")) do
			if tostring(id) == tostring(animId) then
				shouldDribble = true
				break
			end
		end

		if shouldDribble then
			dribble()
		end
	end)
end

local function unhookDribble()
	for _, c in next, dribbleConns do
		c:Disconnect()
	end
	dribbleConns = {}
end

local function scanDribble()
	for _, v in ipairs(game:GetDescendants()) do
		if v:IsA("Humanoid") then
			hookDribble(v)
		end
	end

	if dribbleDescConn then
		dribbleDescConn:Disconnect()
	end
	dribbleDescConn = game.DescendantAdded:Connect(function(d)
		if d:IsA("Humanoid") then
			task.wait(0.3)
			hookDribble(d)
		end
	end)
end

