local oldKick = 0
local canDribble = true
local function onChar(char)
	if char then
		local humanoid = char:WaitForChild("Humanoid")
		local humr = char:WaitForChild("HumanoidRootPart")

		if humanoid and humr then
			local rpData = char:WaitForChild("CHARACTER")
			if rpData then
				local KickChargeMeter = rpData:WaitForChild("KickChargeMeter") :: NumberValue

				if cns["KCM"] then
					cns["KCM"]:Disconnect()
				end

				cns["KCM"] = KickChargeMeter.Changed:Connect(function()
					local newVal = KickChargeMeter.Value
					if newVal == 0 then
						if oldKick > 90 and canDribble then
							canDribble = false
							task.delay(0.3, function()
								canDribble = true
							end)
						end
					end
					oldKick = newVal
				end)
			end
		end
	end
end

cns.OnCharAdded = Players.LocalPlayer.CharacterAdded:Connect(function(a0: Model)
