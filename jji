local level = game:GetService("Players").LocalPlayer.ReplicatedData.level

local function GetAreaFromLVL()
	local lvl = level.Value
	if lvl >= 240 then
		return "Yuki Fortress Set"
	elseif lvl >= 180 then
		return "Kura Camp Set"
	elseif lvl >= 120 then
		return "Numa Temple Set"
	elseif lvl >= 60 then
		return "Umi Village Set"
	else
		return "Shijo Town Set"
	end
end

local function getQuest(numb)
