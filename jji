local function detectHitbox(radius)
	local hits = {}

	for _, mob in CollectionService:GetTagged("Mobs") do
		if mob ~= game.Players.LocalPlayer.Character.Humanoid and mob:IsA("Humanoid") and mob.RootPart and mob:IsDescendantOf(workspace) then
			local hitboxRadius = radius or 10
			local radiusOffset = 0
			local multiplier = 200
			local mobPosition = mob.RootPart.Position
			local playerPosition = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
			local distance = (mobPosition - playerPosition).Magnitude
			if distance <= (hitboxRadius + radiusOffset) * multiplier then
				table.insert(hits, mob)
			end
		end
	end

	return hits
end

