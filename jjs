		if not ownerHumr then
			return
		end

		local startPosition = ownerHumr.Position

		local closestChar = nil
		local closestDistance = 500

		for _, Character in ipairs(characters:GetChildren()) do
			local charInfo = Character:FindFirstChild("Info")
			if
				Character
				and Character ~= myChar
				and Character:FindFirstChild("HumanoidRootPart")
				and Character:FindFirstChild("Humanoid")
				and Character.Humanoid.Health > 0
				and charInfo
				and not charInfo:FindFirstChild("Counter")
				and not table.find(WhiteList, Character.Name)
			then
				local hrp = Character.HumanoidRootPart
				local distance = (hrp.Position - startPosition).Magnitude

				if distance < closestDistance then
					closestDistance = distance
					closestChar = Character
				end
			end
		end

		if closestChar then
			local targetHRP = closestChar.HumanoidRootPart
			local direction = (humr.Position - targetHRP.Position).Unit
			local targetPos = targetHRP.Position + direction * 2
			local targetLookPos = Vector3.new(targetHRP.Position.X, humr.Position.Y, targetHRP.Position.Z)

