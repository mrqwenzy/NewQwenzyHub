local function IsBehindTarget(target, threshold)
	threshold = threshold or 0.7
	local myChar = character()
	if not myChar or not target then
		return false
	end
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	local targetRoot = target:FindFirstChild("HumanoidRootPart")
	if not myRoot or not targetRoot then
		return false
	end
	local toAttacker = (myRoot.Position - targetRoot.Position)
	toAttacker = Vector3.new(toAttacker.X, 0, toAttacker.Z).Unit
	local targetLook = Vector3.new(targetRoot.CFrame.LookVector.X, 0, targetRoot.CFrame.LookVector.Z).Unit
	return targetLook:Dot(toAttacker) >= threshold, targetLook:Dot(toAttacker)
end

--// LOCK-ON SYSTEM

local LockOn = {
	Enabled = false,
	Target = nil,
	Conn = nil,
}

local function SetLockOnTarget(target)
	LockOn.Target = target
	if target then
		WindUI:Notify({ Title = "Locked On", Content = target.Name, Duration = 3, Icon = "crosshair" })
	else
		WindUI:Notify({ Title = "Lock-On", Content = "Target cleared.", Duration = 2, Icon = "x" })
	end
end

local function StartLockOn()
	if LockOn.Conn then
		LockOn.Conn:Disconnect()
	end
	LockOn.Conn = RunService.RenderStepped:Connect(function()
		if not LockOn.Enabled or not LockOn.Target then
			return
		end
		local myChar = character()
		if not myChar then
			return
		end
		local myRoot = myChar:FindFirstChild("HumanoidRootPart")
		local targetRoot = LockOn.Target:FindFirstChild("HumanoidRootPart")
		local hum = LockOn.Target:FindFirstChildOfClass("Humanoid")
		if not targetRoot or not hum or hum.Health <= 0 then
			LockOn.Target = nil
			WindUI:Notify({ Title = "Lock-On", Content = "Target lost.", Duration = 2, Icon = "x" })
			return
		end
		if not myRoot then
			return
		end
		local cam = workspace.CurrentCamera
		local targetPos = targetRoot.Position + Vector3.new(0, 0, 0)
		local camPos = cam.CFrame.Position
		cam.CFrame = CFrame.new(camPos, targetPos)
	end)
end

local function StopLockOn()
	if LockOn.Conn then
		LockOn.Conn:Disconnect()
		LockOn.Conn = nil
	end
end

local function ToggleLockOn()
	if LockOn.Target then
		SetLockOnTarget(nil)
		LockOn.Enabled = false
	else
		local target = GetClosestCharacter(60)
		if target then
			SetLockOnTarget(target)
			LockOn.Enabled = true
			StartLockOn()
		else
			WindUI:Notify({
				Title = "Lock-On",
				Content = "No enemy nearby.",
				Duration = 3,
				Icon = "search",
			})
		end
	end
end

