--// DASH

local function DashBehindTarget(target, duration)
	duration = duration or 0.3
	local myChar = character()
	if not myChar or not target then
		return
	end
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	local targetRoot = target:FindFirstChild("HumanoidRootPart")
	if not myRoot or not targetRoot then
		return
	end

	local cam = workspace.CurrentCamera
	local radius = Config.BackStab.Radius or 4
	local camRadius = radius + 6
	local camElevation = 4
	local maxPlayerRotSpeed = math.rad(120)
	local startPos = myRoot.Position
	local heightY = myRoot.Position.Y
	local elapsed = 0
	local playerAngleOffset = 0
	local lastMousePos = UserInputService:GetMouseLocation()

	local startAngle = (function()
		local off = myRoot.Position - targetRoot.Position
		return math.atan2(off.X, off.Z)
	end)()

	local smoothStartPos = startPos
	local conn
	conn = RunService.RenderStepped:Connect(function(dt)
		local ok = pcall(function()
			elapsed = elapsed + dt
			local alpha = math.min(elapsed / duration, 1)
			local targetPos = targetRoot.Position
			local targetLook = targetRoot.CFrame.LookVector
			local goalAngle = math.atan2(-targetLook.X, -targetLook.Z)
			local delta = (goalAngle - startAngle + math.pi) % (2 * math.pi) - math.pi
			local remaining = 1 - alpha
			local urgency = math.abs(delta) / math.pi
			local boostedAlpha = math.min(alpha + urgency * remaining * dt * 6, 1)
			local t = boostedAlpha * boostedAlpha * (3 - 2 * boostedAlpha)
			local currentMousePos = UserInputService:GetMouseLocation()
			local mouseDeltaX = currentMousePos.X - lastMousePos.X
			lastMousePos = currentMousePos
			local rotDelta = math.clamp(mouseDeltaX * 0.003, -maxPlayerRotSpeed * dt, maxPlayerRotSpeed * dt)
			playerAngleOffset = playerAngleOffset + rotDelta
			local finalAngle = startAngle + delta * t + playerAngleOffset
			local arcPos = targetPos
				+ Vector3.new(math.sin(finalAngle) * radius, heightY - targetPos.Y, math.cos(finalAngle) * radius)
			smoothStartPos = smoothStartPos:Lerp(myRoot.Position, dt * 4)
			local lerpedPos = smoothStartPos:Lerp(arcPos, t)
			myRoot.CFrame = CFrame.lookAt(lerpedPos, Vector3.new(targetPos.X, lerpedPos.Y, targetPos.Z))
			if Config.BackStab.Camera then
				local camPos = targetPos
					+ Vector3.new(
						math.sin(finalAngle) * camRadius,
						(heightY - targetPos.Y) + camElevation,
						math.cos(finalAngle) * camRadius
					)
				cam.CFrame = CFrame.lookAt(camPos, targetPos + Vector3.new(0, 2, 0))
			else
				print("no cam")
			end
			if alpha >= 1 then
				conn:Disconnect()
			end
		end)
		if not ok then
			conn:Disconnect()
		end
	end)
	task.wait(duration)
end --// YUJI FUNCS

