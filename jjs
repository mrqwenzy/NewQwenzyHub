				if isAttacking(closestChar) then
					if not isBlocking(myChar) then
						block(true)
					end
				else
					if isBlocking(myChar) then
						block(false)
					end
					if not isStunned(myChar) then
						if checkRagdoll(closestChar) then
							block(false)

							if ehum and ehum.Health > 0 then
							end
							block(true)
						else
