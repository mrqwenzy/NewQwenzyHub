local fillGrad = Instance.new("UIGradient")
fillGrad.Rotation = 0
fillGrad.Parent = Fill

local t = 0

local function updateGradient()
	t += 0.016 * 0.6
	local offset = math.sin(t) * 0.5 + 0.5

	local p0 = math.clamp(offset - 0.15, 0, 1)
	local p1 = math.clamp(offset, 0, 1)
	local p2 = math.clamp(offset + 0.15, 0, 1)

	if p0 < 0.001 then
		p0 = 0.001
	end
	if p1 <= p0 then
		p1 = p0 + 0.001
	end
	if p2 <= p1 then
		p2 = p1 + 0.001
	end
	if p2 >= 1 then
		p2 = 0.999
	end

	fillGrad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 20)),
		ColorSequenceKeypoint.new(p0, Color3.fromRGB(60, 60, 60)),
		ColorSequenceKeypoint.new(p1, Color3.fromRGB(84, 84, 84)),
		ColorSequenceKeypoint.new(p2, Color3.fromRGB(60, 60, 60)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 20, 20)),
	})
end

