AutoConfig.LastCancel = tick()
local function onKey(input, gameProcessed, isSimulated)
	local gui = Players.LocalPlayer.PlayerGui.Main.Moveset

	task.spawn(function()
		if not gameProcessed and Ver.Value == currVer then
			for _, moveName in ipairs(Config.BackStab.Moves) do
				local key = getMoveKey(moveName)
				if gui[moveName].Cooldown.Size.Y.Scale == 0 then
					if key and input.KeyCode == key then
						local target = GetClosestCharacter(Config.BackStab.Range)
						if target then
							if Config.BackStab.Delay ~= 0 then
								task.delay(Config.BackStab.Delay, function()
									DashBehindTarget(target, Config.BackStab.Speed)
								end)
							else
								DashBehindTarget(target, Config.BackStab.Speed)
							end
						end
					end
				end
			end
		end
	end)
end

local function simulateKeyFromMove(moveName)
	local key = getMoveKey(moveName)
	if not key then
		warn("NO KEY.")
		return
	end
	onKey({ KeyCode = key, UserInputType = Enum.UserInputType.Keyboard }, false, true)
end

local function hookButton(frame)
	if not frame:IsA("Frame") then
		return
	end
	local function onActivated()
		if Ver.Value == currVer then
			simulateKeyFromMove(frame.Name)
		end
	end
	local btn = frame:FindFirstChildWhichIsA("TextButton") or frame:FindFirstChildWhichIsA("ImageButton")
	if btn then
		cns[btn.Name .. "Activated"] = btn.Activated:Connect(onActivated)
	else
		cns["FrameINPUT" .. frame.Name] = frame.InputBegan:Connect(function(inp)
			if
				inp.UserInputType == Enum.UserInputType.Touch
				or inp.UserInputType == Enum.UserInputType.MouseButton1
			then
				onActivated()
			end
		end)
